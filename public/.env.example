# AgentMemory — environment variables
# Copy this file to .env (or set in your hosting provider's dashboard).
# Never commit .env or real secrets to git.

# === Web app (Vite, prefix with VITE_) ===

# Cloud sync via Supabase. Leave empty to run in fully local-only mode.
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === Vercel serverless MCP (api/mcp.ts) ===

# Same URL/keys as the web app, but unprefixed (server-side).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Never expose the service role key to the browser. Only the server uses it
# to validate JWTs. Get it from the same settings page as the anon key.
SUPABASE_SERVICE_ROLE_KEY=

# === Local MCP server (npm run mcp) ===

# Where to persist memories when running outside the browser.
# Defaults to current working directory if unset.
AGENTMEMORY_HOME=
