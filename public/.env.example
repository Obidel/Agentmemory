# AgentMemory — environment variables
# Copy this file to .env (or set in your hosting provider's dashboard).
# Never commit .env or real secrets to git.

# === Web app (Vite, prefix with VITE_) ===

# Cloud sync via Supabase. Leave empty to run in fully local-only mode.
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Hosted MCP endpoint (used by the Backfill page and any web → MCP tooling).
# Defaults to the official Vercel deployment if unset.
# Override when self-hosting: e.g. https://agentmemory.your-domain.com/mcp
VITE_MCP_URL=https://agentmemory-dusky.vercel.app/mcp

# === Vercel serverless MCP (api/mcp.ts) ===

# Same URL/keys as the web app, but unprefixed (server-side).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Never expose the service role key to the browser. Only the server uses it
# to validate JWTs. Get it from the same settings page as the anon key.
SUPABASE_SERVICE_ROLE_KEY=

# === Embeddings (optional but recommended for cloud MCP) ===
# Enables pgvector semantic search via the HuggingFace Inference API.
# Get a free token (no credit card, 30k requests/month):
#   1. Sign up at https://huggingface.co
#   2. https://huggingface.co/settings/tokens  →  New token  →  Read
# Without this key the server still works, but search falls back to BM25+graph only.
HUGGINGFACE_API_KEY=

# === Rate limit (protects the HF free tier) ===
# Max embedding API calls per user per hour. Default 100 leaves headroom
# in the 30k/month HF free tier (≈ 30 users @ 1k calls/day each).
# Set to 0 to disable the limit. Update via the consume_rate_limit RPC.
RATE_LIMIT_PER_HOUR=100

# === Local MCP server (npm run mcp) ===

# Where to persist memories when running outside the browser.
# Defaults to current working directory if unset.
AGENTMEMORY_HOME=
