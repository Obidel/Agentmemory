# AgentMemory.fyi — environment variables
# Copy this file to .env (or set in your hosting provider's dashboard).
# Never commit .env or real secrets to git.

# === Web app (Vite, prefix with VITE_) ===

VITE_POLAR_TOKEN=
VITE_POLAR_ORG=

# === MCP server ===

# License key for paid plans (Solo/Team). Leave empty for free tier.
# Get it from the activation email after purchasing on your Polar store.
AGENTMEMORY_LICENSE=

# Secret used to verify the license key. Must match LICENSE_SIGNING_SECRET
# on the webhook handler. Leave empty in dev (verification is skipped).
AGENTMEMORY_LICENSE_SECRET=

# Where to persist memories when running outside the browser.
# Defaults to current working directory if unset.
AGENTMEMORY_HOME=

# === Polar webhook handler (api/polar/webhook.ts) ===

POLAR_TOKEN=
POLAR_ORG=
POLAR_WEBHOOK_SECRET=
LICENSE_SIGNING_SECRET=
APP_URL=http://localhost:3000
PORT=3001

# === Supabase (optional, for cloud sync) ===

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
